    background: #eaeaea;
  }

  .product-accordion .arrow {
    transition: transform 0.3s ease;
  }

  .product-accordion input:checked + label .arrow {
    transform: rotate(90deg);
  }

  .product-accordion .content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.3s ease;
    padding: 0 18px;
    background: #fff;
  }

  .product-accordion input:checked ~ .content {
